{
  "name": "@hyrioo/vue-material-symbol",
  "version": "0.1.0",
  "description": "Vue 3 component for Material Symbols SVG icons (uses vite-plugin registry)",
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "vue": "^3.3.0",
    "@hyrioo/vite-plugin-material-symbols-svg": "^0.1.0"
  },
  "scripts": {
    "build": "vite build && yarn build:types",
    "build:types": "vue-tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "vite build --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@hyrioo/vite-plugin-material-symbols-svg": "^0.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.3.0",
    "vue-tsc": "^2.0.0"
  }
}
